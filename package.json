{
  "name": "@holy-two/data-theme",
  "description": "A setting for mounting themes.",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "astro:dev": "pnpm -C ./example/astro dev",
    "build": "pnpm -C ./package build",
    "dev": "concurrently -n build,astro -c blue,green \"pnpm -C ./package dev\" \"pnpm -C ./example/astro dev\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "typescript": "^5.9.2"
  }
}